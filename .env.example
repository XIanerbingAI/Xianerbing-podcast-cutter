# ===== 基础 =====
HOST=0.0.0.0
PORT=8000
MAX_UPLOAD_MB=2048

# ===== 转写 =====
# tiny/base/small/medium/large-v3。GPU 优先用 large-v3;无显卡可改回 medium + cpu + int8
WHISPER_MODEL=large-v3
# auto / cpu / cuda。auto 会优先使用 CTranslate2 能识别到的 CUDA GPU
WHISPER_DEVICE=auto
WHISPER_COMPUTE=int8_float16
WHISPER_LANGUAGE=zh
BEAM_SIZE=5
VAD_FILTER=true

# ===== 默认剪辑力度:conservative / balanced / aggressive =====
DEFAULT_STRENGTH=balanced

# ===== 平滑剪辑 =====
CROSSFADE_MS=40
ACOUSTIC_VALLEY_RADIUS_MS=100
ENERGY_GUARD_THRESHOLD=0.6
INTERNAL_GAP_MS=40
FILL_FLOOR_NOISE=true
TARGET_PAUSE_MS=280
MIN_CUT_MS=60

# ===== 响度归一(EBU R128 播客标准 -16 LUFS)=====
LOUDNORM_TARGET_LUFS=-16.0
LOUDNORM_TRUE_PEAK=-1.5
LOUDNORM_LRA=11.0

# ===== LLM 复核(可选,不填则纯离线规则)=====
# OpenAI 兼容接口。示例:
#   DeepSeek: https://api.deepseek.com/v1   model=deepseek-v4-flash
#   通义:     https://dashscope.aliyuncs.com/compatible-mode/v1  model=qwen-plus
#   OpenAI:   https://api.openai.com/v1     model=gpt-4o-mini
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=deepseek-v4-flash
LLM_TIMEOUT_SEC=20
LLM_ENABLED=false

# ===== 任务队列 =====
USE_CELERY=false
CELERY_BROKER=redis://localhost:6379/0
